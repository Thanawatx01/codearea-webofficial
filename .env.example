# App Name
NEXT_PUBLIC_APP_NAME=CodeArea

# Frontend Base URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend API — callApi() ฐานปกติ (isAI=false ค่าเริ่มต้น)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# บริการ AI — callApi(..., { isAI: true }) ใช้ฐานนี้แทน NEXT_PUBLIC_API_URL (ถ้าไม่ตั้งจะ fallback เป็นบรรทัดบน)
# ถ้าไม่ใส่ http:// จะเติมให้เป็น http:// อัตโนมัติ (กัน relative URL ผิด เช่น …/questions/127.0.0.1:8000/…)
NEXT_PUBLIC_AI_URL=http://127.0.0.1:8000
# path ต่อท้ายฐาน AI สำหรับคำใบ้ (fetchQuestionHint — หรือส่ง options.path)
# NEXT_PUBLIC_QUESTION_HINT_PATH=api/hint
# เปรียบเทียบโค้ด (streamQuestionCodeCompare → POST .../api/compare) — ค่าเริ่มต้น api/compare
# NEXT_PUBLIC_QUESTION_COMPARE_PATH=api/compare
# การวิเคราะห์หลังส่งโค้ด (streamPostSubmitAnalysis → POST .../analyze) ใช้ isAI ค่าเริ่มต้น true = ฐานบรรทัดนี้

# Upload Assets (pointing to backend static folder)
NEXT_PUBLIC_UPLOAD_BASE_URL=http://localhost:5000/assets
